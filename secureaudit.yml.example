# SecureAudit configuration
# Place this file at the root of your project as secureaudit.yml

# Plugins to run (comment out to disable)
plugins:
  - secrets
  - cve
  - filesystem
  - http
  - network
  - policy
  - cors
  - git_history
  # Opt-in (require external binaries — see docs):
  # - sast        # requires: pip install semgrep
  # - malware     # requires: apt install clamav
  # - trivy       # requires: https://aquasecurity.github.io/trivy/

# Fail CI if score drops below this
fail_below: 70

# Optional — groups this target's scan history with others under one name
# for a portfolio view (secureaudit projects --db audits.db)
# project: my-app

# Paths to exclude from scanning
exclude_paths:
  - .git
  - node_modules
  - .venv
  - __pycache__
  - dist
  - build
  - .terraform

# ── Plugin configuration ──────────────────────────────────────────────────────

secrets:
  exclude_extensions:
    - .png
    - .jpg
    - .gif
    - .svg
    - .pdf
    - .zip
  max_file_size_kb: 512

cve:
  ecosystems:
    - PyPI
    - npm
    - Go
  fail_on_severity:
    - CRITICAL
    - HIGH

http:
  timeout: 10
  urls:
    - https://example.com   # add your URLs here
  ssl_expiry_warning_days: 30

network:
  hosts:
    - example.com           # add your hosts here
  ports: [21, 22, 23, 80, 443, 3306, 5432, 6379]
  timeout: 2

policy:
  ssl_expiry_warning_days: 30

report:
  output_dir: ./secureaudit-reports
  formats:
    - html
    - json

cors:
  urls:
    - https://api.example.com   # add your API URLs here

git_history:
  since_days: 90
  max_commits: 200
  max_findings: 50

sast:
  config: auto          # or "p/owasp-top-ten", "p/security-audit"
  timeout: 120

malware:
  scan_dirs: [node_modules, .venv, vendor, uploads, dist, build]
  max_file_size_mb: 50
  max_definition_age_days: 7

trivy:
  timeout: 180
  scan_images: false     # set true + 'image: name:tag' to scan a built image
  # image: myapp:latest

# ── Baseline & suppressions ───────────────────────────────────────────────────
#
# Accept existing findings so they don't reappear on every scan:
#   secureaudit baseline .
# Creates .secureaudit-baseline.json — commit this file so the team shares
# the same accepted-risk baseline. Suppressed findings still show in reports
# (labelled "baseline"), just excluded from the score.
#
# Inline suppression — add a comment on the offending line:
#   API_KEY = "test-fixture-not-real"  # secureaudit-ignore
#   API_KEY = "test-fixture-not-real"  # secureaudit-ignore: hardcoded-password
#   API_KEY = "test-fixture-not-real"  # secureaudit-ignore: hardcoded-password reason="test fixture"
#   API_KEY = "test-fixture-not-real"  # secureaudit-ignore: hardcoded-password until=2026-12-31
#
# The 'until' date forces re-review — after that date the finding becomes
# active again instead of being silenced forever.

# ── Notifications ──────────────────────────────────────────────────────────
#
# Slack/Teams are passed as CLI flags, not config (webhook URLs are secrets):
#   secureaudit scan . --alert-slack https://hooks.slack.com/services/...
#   secureaudit scan . --alert-teams https://outlook.office.com/webhook/...
#   secureaudit schedule . --cron "0 6 * * 1" --alert-slack URL --dashboard-url https://...
#   secureaudit digest . --db audits.db --slack-webhook URL --days 7

# ── Incremental scanning ──────────────────────────────────────────────────────
#
# Enabled by default for secrets, sast and policy (Dockerfile/CI checks).
# Cache lives in .secureaudit-cache/ next to the scanned target — add it to
# .gitignore (already handled if you cloned secureaudit's own .gitignore as
# a starting point).
#
#   secureaudit scan .              # cache used automatically
#   secureaudit scan . --no-cache   # force a full rescan
#   secureaudit cache status .
#   secureaudit cache clear .
